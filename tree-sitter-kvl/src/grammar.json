{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "kvl",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "header"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "list_item"
          },
          {
            "type": "SYMBOL",
            "name": "pair"
          },
          {
            "type": "SYMBOL",
            "name": "continuation"
          },
          {
            "type": "SYMBOL",
            "name": "_blank"
          }
        ]
      }
    },
    "header": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]*#[^ \\t\\n]+[ \\t]+kvl[ \\t]+[0-9]+\\.[0-9]+[^\\n]*\\n"
        }
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 8,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]*\\/=[^\\n]*\\n"
        }
      }
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "list_marker"
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]"
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "value"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "list_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "[-+*]"
        }
      }
    },
    "pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "key"
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "FIELD",
          "name": "separator",
          "content": {
            "type": "SYMBOL",
            "name": "separator"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[ \\t]+"
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "SYMBOL",
                    "name": "value"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "separator": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": ":="
            },
            {
              "type": "STRING",
              "value": "->"
            },
            {
              "type": "STRING",
              "value": "="
            },
            {
              "type": "STRING",
              "value": ":"
            }
          ]
        }
      }
    },
    "value": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "_blank": {
      "type": "PATTERN",
      "value": "[ \\t]*\\n"
    },
    "_eol": {
      "type": "PATTERN",
      "value": "\\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "key"
    },
    {
      "type": "SYMBOL",
      "name": "continuation"
    },
    {
      "type": "SYMBOL",
      "name": "_error_sentinel"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}